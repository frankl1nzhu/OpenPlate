rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Foods - shared across all users, any authenticated user can read/create/update
    match /foods/{foodId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      // Only admins can delete
      allow delete: if request.auth != null
        && request.auth.token.admin == true;
    }

    // Meals - per-user, owner can manage their own meals
    match /meals/{mealId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      // Owner or admin can delete
      allow delete: if request.auth != null
        && (resource.data.createdBy == request.auth.uid
            || request.auth.token.admin == true);
    }

    // Delete requests - any authenticated user can create, only admin can update/delete
    match /deleteRequests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.status == 'pending';
      allow update, delete: if request.auth != null
        && request.auth.token.admin == true;
    }

    // User profiles - owner can read/write, admin can read all
    match /userProfiles/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId || request.auth.token.admin == true);
      allow write: if request.auth != null
        && request.auth.uid == userId;
    }

    // Daily logs - only the owner can read/write
    match /dailyLogs/{logId} {
      allow read, write: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // Daily goals - only the owner can read/write
    match /dailyGoals/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // Fitness goals - only the owner can read/write
    match /fitnessGoals/{goalId} {
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }
  }
}
