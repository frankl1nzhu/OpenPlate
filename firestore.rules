rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Foods - shared across all users, any authenticated user can read/create/update
    match /foods/{foodId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      // Only admins can delete (via console or Cloud Functions)
      allow delete: if false;
    }

    // Meals - shared across all users, any authenticated user can CRUD
    match /meals/{mealId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Delete requests - any authenticated user can create, only admin can update
    match /deleteRequests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.status == 'pending';
      // Only admin can approve/reject (handle via Cloud Functions or console)
      allow update, delete: if false;
    }

    // Daily logs - only the owner can read/write
    match /dailyLogs/{logId} {
      allow read, write: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // Daily goals - only the owner can read/write
    match /dailyGoals/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }
  }
}
