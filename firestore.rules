rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Foods - shared across all users, any authenticated user can CRUD
    match /foods/{foodId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Meals - shared across all users, any authenticated user can CRUD
    match /meals/{mealId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Daily logs - only the owner can read/write
    match /dailyLogs/{logId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // Daily goals - only the owner can read/write
    match /dailyGoals/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }
  }
}
